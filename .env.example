# Cloudflare Credentials (for drizzle-kit remote migrations)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id
CLOUDFLARE_D1_TOKEN=your_api_token

# App Secret (set as Cloudflare Pages environment variable)
JWT_SECRET=your-strong-random-secret-here

# Stripe (set as Cloudflare Pages environment variables)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...   # $3/month recurring price ID from Stripe dashboard
